# Backend - .env file
# Copy this to backend/.env and fill in your values

# MongoDB Connection String from Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster-name.mongodb.net/tripbloom?retryWrites=true&w=majority

# Server Port (Railway will set this automatically)
PORT=5000

# Optional settings
HOME_COUNTRY=Bangladesh
NODE_ENV=production

# Frontend URL (for CORS - set to your Vercel URL)
FRONTEND_URL=https://your-frontend.vercel.app
