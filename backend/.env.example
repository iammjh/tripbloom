# MongoDB Connection String from Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster-name.mongodb.net/tripbloom?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production

# CORS / Frontend URLs
CORS_ORIGIN=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Optional settings
HOME_COUNTRY=Bangladesh
MAX_FILE_SIZE=5242880
