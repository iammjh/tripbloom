{
  "version": 2,
  "buildCommand": "npm install && npm run install-all && npm run build --prefix frontend",
  "framework": "nodejs",
  "functions": {
    "backend/**": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/index.js"
    },
    {
      "source": "/:path((?!api).*)*",
      "destination": "/index.html"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "NODE_ENV": "production",
    "PORT": "3001"
  }
}
